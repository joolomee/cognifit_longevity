{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, follow"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://brain.cognifit.com https://*.wixsite.com https://*.wix.com"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
